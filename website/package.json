{
	"name": "website",
	"version": "0.0.1",
	"private": true,
	"license": "Apache-2.0 with Commons Clause",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview --port 3000",
		"lint": "prettier --check \"**/*\" -u && eslint . --ext .js,.ts,.svelte && pnpm run svelte:check",
		"svelte:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"svelte:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write \"**/*\" -u"
	},
	"devDependencies": {
		"@fortawesome/free-brands-svg-icons": "^6.6.0",
		"@fortawesome/free-regular-svg-icons": "^6.6.0",
		"@sveltejs/adapter-static": "^3.0.4",
		"@sveltejs/kit": "^2.5.27",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.44.0",
		"moment": "^2.30.1",
		"phosphor-svelte": "^1.4.2",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.6",
		"sass": "^1.78.0",
		"svelte": "^4.2.19",
		"svelte-check": "^3.8.6",
		"svelte-fa": "^4.0.2",
		"svelte-i18n": "^4.0.0",
		"tslib": "^2.7.0",
		"typescript": "^5.6.2",
		"vite": "^5.4.5"
	},
	"type": "module"
}
